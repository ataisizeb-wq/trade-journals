import { useState } from 'react'
import { supabase } from '../lib/supabase'

export default function TradeForm({ user }) {
  const [pair, setPair] = useState('')
  const [entry, setEntry] = useState('')
  const [exit, setExit] = useState('')

  const saveTrade = async () => {
    const profit_loss = exit - entry
    const result = profit_loss >= 0 ? 'win' : 'loss'

    await supabase.from('trades').insert([{
      user_id: user.id,
      pair,
      entry_price: entry,
      exit_price: exit,
      profit_loss,
      result
    }])

    alert('Saved')
  }

  return (
    <div>
      <input placeholder="Pair" onChange={e => setPair(e.target.value)} />
      <input placeholder="Entry" onChange={e => setEntry(e.target.value)} />
      <input placeholder="Exit" onChange={e => setExit(e.target.value)} />

      <button onClick={saveTrade}>Save Trade</button>
    </div>
  )
}
